# AA Points Monitor - Environment Variables
# Copy this file to .env and fill in your values

# Resend API (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Alert Recipients (comma-separated)
ALERT_EMAIL_TO=user@example.com,user@example.com

# Alert Sender
ALERT_EMAIL_FROM=alerts@example.com

# Timezone
TZ=America/Chicago

# Database path (relative to project root)
DATABASE_PATH=data/aa_monitor.db

# Browser data path (for Playwright persistent context)
BROWSER_DATA_PATH=browser_data

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Push Notifications (choose one)

# Option 1: ntfy.sh (free, recommended)
# Install ntfy app on your phone and subscribe to your topic
NTFY_TOPIC=aa-points-yourname

# Option 2: Pushover ($5 one-time)
# PUSHOVER_USER_KEY=xxxxxx
# PUSHOVER_APP_TOKEN=xxxxxx

