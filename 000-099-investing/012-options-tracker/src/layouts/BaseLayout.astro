---
interface Props { title?: string }
const { title = 'LEAPS Tracker' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-bg-primary text-text-primary">
  <nav class="sticky top-0 z-50 border-b border-border bg-bg-primary/80 backdrop-blur-lg">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <h1 class="text-lg font-bold text-accent">LEAPS Tracker</h1>
      <span id="last-updated" class="text-xs text-text-secondary"></span>
    </div>
  </nav>
  <main class="mx-auto max-w-6xl px-6 py-8">
    <slot />
  </main>
</body>
</html>
